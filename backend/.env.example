# Database Configuration
DB_HOST=localhost
DB_PORT=5434
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
# Generate a secure random string for production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# Application Configuration
APP_PORT=8080
ENV=development
APP_BASE_URL=http://localhost:5173

# Resend (optional; if empty, email links are logged to backend console)
RESEND_API_KEY=
RESEND_FROM=

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=info

# Anthropic (TourKZ chat assistant; required for POST /api/v1/chat/message)
ANTHROPIC_API_KEY=

# PayPal (REST v2; sandbox: https://developer.paypal.com/ — use sandbox client id/secret)
# If unset, POST /bookings/:id/paypal/checkout returns 503
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# true = api-m.sandbox.paypal.com, false = production api-m.paypal.com
PAYPAL_SANDBOX=true

# Polar (https://polar.sh/docs) — org access token, product with custom amount, sandbox
# Webhook: POST {APP} must be /api/v1/webhooks/polar, subscribe to order.paid, copy signing secret
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
POLAR_SANDBOX=true
